VOICESHIELD_DATABASE_PATH=backend/data/voiceshield.db
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VOICESHIELD_ENCRYPTION_KEY=
# JSON object: token -> user and role. Use long random tokens and a secret manager in production.
VOICESHIELD_API_TOKENS={"replace-with-random-token":{"userId":"local-reviewer","role":"admin"}}
VOICESHIELD_CORS_ORIGINS=http://localhost:5173
VOICESHIELD_MODEL_PATH=ml/artifacts/baseline/classifier.joblib
VOICESHIELD_RETAIN_AUDIO=false
VOICESHIELD_MAX_AUDIO_BYTES=26214400
# Optional server STT. Requires requirements-stt.txt.
VOICESHIELD_WHISPER_MODEL=
VOICESHIELD_WHISPER_DEVICE=cpu
VOICESHIELD_WHISPER_COMPUTE_TYPE=int8

