VOICESHIELD_DATABASE_PATH=backend/data/voiceshield.db
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VOICESHIELD_ENCRYPTION_KEY=
# JSON object: token -> user and role. Use long random tokens and a secret manager in production.
VOICESHIELD_API_TOKENS={"replace-with-random-token":{"userId":"local-reviewer","role":"admin"}}
VOICESHIELD_CORS_ORIGINS=http://localhost:5173
VOICESHIELD_MODEL_PATH=ml/artifacts/baseline/classifier.joblib
VOICESHIELD_RETAIN_AUDIO=false
VOICESHIELD_MAX_AUDIO_BYTES=26214400
# Optional ElevenLabs voice for the training simulator only. Never put these in the APK.
ELEVENLABS_API_KEY=
ELEVENLABS_TRAINING_VOICE_ID=
ELEVENLABS_TRAINING_MODEL=eleven_multilingual_v2
VOICESHIELD_TRAINING_TTS_CACHE=backend/data/training-tts-cache
# Microsoft Edge Neural voices. No API key is required, but the backend needs internet access.
VOICESHIELD_EDGE_TTS_ENABLED=true
VOICESHIELD_EDGE_TTS_VOICE_RU=ru-RU-SvetlanaNeural
VOICESHIELD_EDGE_TTS_VOICE_KZ=kk-KZ-AigulNeural
# Base64 raw 32-byte Ed25519 private key for OTA manifests. Keep only in a secret manager.
VOICESHIELD_OTA_PRIVATE_KEY_B64=
# Optional backend-only external lookups. Never put these in the APK.
# Configure one number provider, not both, unless you want automatic fallback.
NUMVERIFY_API_KEY=
ABSTRACTAPI_PHONE_API_KEY=
PHISHTANK_API_KEY=
VOICESHIELD_EXTERNAL_INTEL_TIMEOUT_SECONDS=8
# Optional server STT. Requires requirements-stt.txt.
VOICESHIELD_WHISPER_MODEL=
VOICESHIELD_WHISPER_DEVICE=cpu
VOICESHIELD_WHISPER_COMPUTE_TYPE=int8
# Optional local-network LiveKit server. Keep the secret on the backend, never in the APK.
# Use the Mac LAN address, e.g. ws://192.168.1.10:7880, so Android can reach it.
LIVEKIT_URL=ws://192.168.1.10:7880
LIVEKIT_API_KEY=replace-with-random-key
LIVEKIT_API_SECRET=replace-with-random-secret
